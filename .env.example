# Bridge service
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8788
LOG_LEVEL=info

# Optional simple policy knobs
DANGEROUS_TOOLS=exec,apply_patch
BLOCK_PATTERNS=rm -rf,shutdown,reboot
APPROVAL_PATTERNS=delete,drop,truncate,chmod 777

# Plugin -> bridge
KOGWISTAR_BRIDGE_URL=http://host.docker.internal:8788
KOGWISTAR_PLUGIN_TIMEOUT_MS=3000
